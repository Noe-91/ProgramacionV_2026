@model ProgramacionV_2026.Models.UsuarioViewModel

@{
    ViewData["Title"] = "Alta de Usuario";
}

<style>
    .user-page {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .user-card {
        width: 100%;
        max-width: 650px;
        background: rgba(255,255,255,0.95);
        border-radius: 22px;
        padding: 35px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.25);
    }

    .user-header {
        display: flex;
        align-items: center;
        gap: 18px;
        margin-bottom: 30px;
        border-bottom: 1px solid #ddd;
        padding-bottom: 20px;
    }

    .user-icon {
        width: 70px;
        height: 70px;
        border-radius: 18px;
        background: #1e3c72;
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 32px;
    }

    .user-title {
        margin: 0;
        font-weight: 700;
        color: #1e3c72;
    }

    .user-subtitle {
        margin: 0;
        color: #666;
    }

    .form-label {
        font-weight: 600;
        color: #1e3c72;
    }

    .form-control {
        height: 48px;
        border-radius: 12px;
    }

    .btn-save {
        height: 48px;
        border-radius: 12px;
        font-weight: 600;
        background: #1e3c72;
        border: none;
    }

        .btn-save:hover {
            background: #2a5298;
        }
</style>

<div class="user-page">

    <div class="user-card">

        <div class="user-header">

            <div class="user-icon">
                <i class="fa-solid fa-user-plus"></i>
            </div>

            <div>
                <h2 class="user-title">Alta de Usuario</h2>
                <p class="user-subtitle">Completá los datos para registrar un nuevo usuario</p>
            </div>

        </div>

        <form asp-controller="Usuario" asp-action="Create" method="post">

            <div class="mb-3">
                <label class="form-label">Nombre de usuario</label>
                <input asp-for="Username"
                       class="form-control"
                       placeholder="Ejemplo: noelia" />
            </div>

            <div class="mb-4">
                <label class="form-label">Contraseña</label>
                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       placeholder="Ingresá una contraseña" />
            </div>

            <div class="d-flex justify-content-end gap-2">

                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-outline-secondary px-4">
                    Cancelar
                </a>

                <button type="submit" class="btn btn-primary btn-save px-4">
                    <i class="fa-solid fa-floppy-disk me-2"></i>
                    Guardar Usuario
                </button>

            </div>

        </form>
        @if (ViewBag.UsuarioInsertado != null)
        {
            <div class="alert alert-success mt-4 d-flex align-items-center">

                <i class="fa-solid fa-circle-check me-3 fs-4"></i>

                <div>
                    <strong>Usuario creado correctamente</strong>
                    <br />
                    El usuario
                    <strong>@ViewBag.UsuarioInsertado</strong>
                    fue registrado con éxito.
                </div>

            </div>
        }

        @if (ViewBag.Mensaje != null)
        {
            <div class="alert alert-success mt-4">
                <i class="fa-solid fa-circle-check me-2"></i>
                @ViewBag.Mensaje
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mt-4">
                <i class="fa-solid fa-circle-exclamation me-2"></i>
                @ViewBag.Error
            </div>
        }

    </div>

</div>