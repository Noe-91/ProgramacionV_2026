<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>ProgramacionV_2026</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProgramacionV_2026.styles.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <style>
            body {
                min-height: 100vh;
                background: linear-gradient(135deg, #1e3c72, #2a5298);
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            .navbar-custom {
                background: rgba(255, 255, 255, 0.95);
                backdrop-filter: blur(10px);
                box-shadow: 0 4px 15px rgba(0,0,0,0.15);
            }

            .navbar-brand {
                font-weight: 700;
                color: #1e3c72 !important;
            }

            .nav-link {
                font-weight: 500;
                color: #1e3c72 !important;
            }

                .nav-link:hover {
                    color: #2a5298 !important;
                }

            main {
                padding-top: 40px;
                padding-bottom: 80px;
            }

            .footer-custom {
                background: rgba(255,255,255,0.95);
                color: #1e3c72;
                padding: 15px 0;
                box-shadow: 0 -4px 15px rgba(0,0,0,0.08);
            }

                .footer-custom a {
                    color: #1e3c72;
                    font-weight: 600;
                }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light navbar-custom">
            <div class="container-fluid px-4">

                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-code me-2"></i>
                    ProgramacionV_2026
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">

                    <ul class="navbar-nav">

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-house me-1"></i>
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Actividad" asp-action="Index">
                                <i class="fa-solid fa-calendar-days me-1"></i>
                                Talleres
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Usuario" asp-action="Create">
                                <i class="fa-solid fa-user-plus me-1"></i>
                                Alta Usuario
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="fa-solid fa-shield-halved me-1"></i>
                                Privacy
                            </a>
                        </li>

                    </ul>

                </div>

            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom fixed-bottom">
        <div class="container text-center">
            &copy; 2026 - ProgramacionV_2026
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>